generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id Int @default(autoincrement()) @id
  email String @unique
  password String
  name String
  surname String
  refreshToken String?
  completed_simulations Int @default(0)
  average_score Int?
  survival_rate Int?
  correct_diagnosis_rate Int?
  sessions Sessions[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sessions {
  id Int @default(autoincrement()) @id
  user Users @relation(fields: [user_id], references: [id])
  user_id Int
  specialty Specialty
  score Int?
  patient_survived Boolean?
  correct_diagnosis Boolean?
  duration_seconds Int?
  status SessionStatus @default(ACTIVE)
  patient_name String?
  patient_age Int?
  patient_gender String?
  patient_weight Int?
  known_allergies String?
  condition String?
  final_diagnosis String?
  history Json @default("[]")
  systemAnalysis String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([user_id])
}

enum Specialty {
  TRAUMATOLOGY
  CARDIOLOGY
  EMERGENCY_MEDICINE
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}
