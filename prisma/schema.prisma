generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id Int @default(autoincrement()) @id
  email String @unique
  password String
  name String
  surname String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}