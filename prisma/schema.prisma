generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id Int @default(autoincrement()) @id
  email String @unique
  password String
  name String
  surname String
  refreshToken String?
  completed_simulations Int @default(0)
  average_score Int?
  survival_rate Int?
  correct_diagnosis_rate Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}